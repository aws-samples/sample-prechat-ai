{
  "name": "mte-pre-consultation-chatbot",
  "version": "1.0.0",
  "description": "A conversational AI web system for AWS sales team pre-meeting preparation",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspaces run build",
    "test": "npm --workspaces run test",
    "lint": "npm --workspaces run lint",
    "dev": "npm --workspace @mte-prechat/web-app run dev",
    "preview": "npm --workspace @mte-prechat/web-app run preview"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "overrides": {
    "@cloudscape-design/component-toolkit": "1.0.0-beta.157",
    "@cloudscape-design/components": "3.0.1285"
  }
}
